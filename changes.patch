@@ -0,0 +1,90 @@
+#include "subsystem/renderer_gui.h"
+#include <SDL2/SDL.h>
+#include <cstdlib>
+#include <iostream>
+#include "base/logger.h"
+
+RendererGUI::RendererGUI(std::mutex& canvas_mutex)
+    : window_(nullptr), sdl_renderer_(nullptr), canvas_mutex_(canvas_mutex) {
+  if (SDL_Init(SDL_INIT_VIDEO) < 0) {
+    Logger::getInstance().Log(
+        LogLevel::ERROR, std::string("SDL_Init failed: ") + SDL_GetError());
+    std::exit(1);
+  }
+  /* Create SDL window: title, centered position,
+  size 800x600, shown and resizable. */
+  window_ = SDL_CreateWindow("Shard Engine", SDL_WINDOWPOS_CENTERED,
+                             SDL_WINDOWPOS_CENTERED, 800, 600,
+                             SDL_WINDOW_SHOWN | SDL_WINDOW_RESIZABLE);
+  if (!window_) {
+    Logger::getInstance().Log(
+        LogLevel::ERROR,
+        std::string("SDL_CreateWindow failed: ") + SDL_GetError());
+    SDL_Quit();
+    std::exit(1);
+  }
+  sdl_renderer_ = SDL_CreateRenderer(
+      window_, -1, SDL_RENDERER_ACCELERATED | SDL_RENDERER_PRESENTVSYNC);
+  if (!sdl_renderer_) {
+    Logger::getInstance().Log(
+        LogLevel::ERROR,
+        std::string("SDL_CreateRenderer failed: ") + SDL_GetError());
+    SDL_DestroyWindow(window_);
+    SDL_Quit();
+    std::exit(1);
+  }
+  // Set initial size in RendererBase
+  SetSize(800, 600);
+  Logger::getInstance().Log(LogLevel::INFO,
+                            "RendererGUI initialized successfully with SDL.");
+}
+
+RendererGUI::~RendererGUI() {
+  Logger::getInstance().Log(LogLevel::INFO, "RendererGUI destructor called");
+  if (sdl_renderer_) {
+    SDL_DestroyRenderer(sdl_renderer_);
+  }
+  if (window_) {
+    SDL_DestroyWindow(window_);
+  }
+  SDL_Quit();
+}
+
+void RendererGUI::ClearDisplay() {
+  std::lock_guard<std::mutex> lock(canvas_mutex_);
+  // Clear with a dark background color.
+  SDL_SetRenderDrawColor(sdl_renderer_, 30, 30, 30, 255);
+  SDL_RenderClear(sdl_renderer_);
+}
+
+void RendererGUI::ShowText(const std::string& text, int x, int y) {
+  std::lock_guard<std::mutex> lock(canvas_mutex_);
+  // Demo: draw a light-colored rectangle at the given position.
+  SDL_Rect rect = {x, y, 200, 50};
+  SDL_SetRenderDrawColor(sdl_renderer_, 200, 200, 200, 255);
+  SDL_RenderFillRect(sdl_renderer_, &rect);
+}
+
+void RendererGUI::ShowText(const std::vector<std::string>& text_area, int x,
+                           int y) {
+  if (!text_area.empty()) {
+    ShowText(text_area[0], x, y);
+  }
+}
+
+void RendererGUI::Render() {
+  // Present the drawn frame.
+  SDL_RenderPresent(sdl_renderer_);
+  // Signal that the frame has been redrawn.
+  redrawn();
+}
+
+void RendererGUI::ProcessEvents(bool& quit) {
+  SDL_Event event;
+  while (SDL_PollEvent(&event)) {
+    if (event.type == SDL_QUIT) {
+      quit = true;
+    }
+    // Handle other events here
+  }
+}
