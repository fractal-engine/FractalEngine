+#include "editor_gui.h"
+#include <SDL2/SDL.h>
+#include <chrono>
+#include <thread>
+#include "base/logger.h"
+#include "subsystem/renderer_gui.h"
+
+EditorGUI::EditorGUI(std::mutex& canvas_mutex,
+                     std::shared_ptr<RendererBase> renderer)
+    : canvas_mutex_(canvas_mutex),
+      renderer_(std::move(renderer)),
+      quit_(false) {}
+
+EditorGUI::~EditorGUI() {}
+
+void EditorGUI::Run() {
+  Logger::getInstance().Log(LogLevel::INFO, "EditorGUI main loop start");
+  RendererGUI* sdlRenderer = dynamic_cast<RendererGUI*>(renderer_.get());
+  if (!sdlRenderer) {
+    Logger::getInstance().Log(LogLevel::ERROR,
+                              "Renderer is not of type RendererGUI.");
+    return;
+  }
+
+  SDL_Event event;
+  while (!quit_) {
+    // SDL EVENT LOOP
+    while (SDL_PollEvent(&event)) {
+      if (event.type == SDL_QUIT) {
+        Logger::getInstance().Log(LogLevel::INFO, "SDL_QUIT event received");
+        quit_ = true;
+        editor_exit_pressed();  // Signal game to terminate
+        break;                  // Exit event loop immediately
+      }
+    }
+
+    if (quit_)
+      break;  // Exit render loop immediately when quitting
+
+    sdlRenderer->ClearDisplay();
+    sdlRenderer->ShowText("Hello SDL", 50, 50);
+    sdlRenderer->Render();
+
+    // std::this_thread::sleep_for(std::chrono::milliseconds(16));
+  }
+
+  Logger::getInstance().Log(LogLevel::INFO, "EditorGUI main loop exited");
+}
+
+void EditorGUI::RequestUpdate() {
+  /* In SDL, we redraw continuously. This can be left
+  empty or used to trigger a redraw. */
+}
